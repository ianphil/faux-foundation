# Environment variables for Faux Foundation
# These are loaded automatically by scripts/dev.ps1 from `azd env get-values`.
# If not using azd, copy this to .env and fill in values.

GITHUB_TOKEN=
COPILOT_TOKEN=
BRAVE_API_KEY=

# Repo to clone on boot (owner/name):
MIND_REPO=ianphil/macgyver

# Optional runtime overrides:
# COPILOT_MODEL=
# COPILOT_RESPONSE_TIMEOUT_MS=120000

# Star poller config:
POLL_INTERVAL=30s
