# Copy to .env and set your token.

GITHUB_TOKEN=

# Repo to clone on boot (owner/name):
MIND_REPO=ianphil/faux-foundation

# Optional runtime overrides:
# COPILOT_MODEL=
# COPILOT_RESPONSE_TIMEOUT_MS=120000

# Compose port mapping:
APP_HOST_PORT=3000
DAPR_HTTP_HOST_PORT=3500

# Star poller config:
POLL_INTERVAL=30s
