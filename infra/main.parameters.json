    },
    "authClientId": {
      "value": "${AUTH_CLIENT_ID=}"
    },
    "authClientSecret": {
      "value": "${AUTH_CLIENT_SECRET=}"
    },
    "authAllowedPrincipal": {
      "value": "${AUTH_ALLOWED_PRINCIPAL=}"
    },
    "chatCustomDomain": {
      "value": "${CHAT_CUSTOM_DOMAIN=}"
    },
    "bingApiKey": {
      "value": "${BING_API_KEY=}"
    }
  }
