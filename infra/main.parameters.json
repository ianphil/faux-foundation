{
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "githubToken": {
      "value": "${GITHUB_TOKEN}"
    },
    "copilotToken": {
      "value": "${COPILOT_TOKEN}"
    },
    "mindRepo": {
      "value": "${MIND_REPO=ianphil/macgyver}"
    },
    "pollInterval": {
      "value": "${POLL_INTERVAL=30s}"
